{
  "name": "smarthire-portal",
  "version": "1.0.0",
  "description": "SmartHire Recruitment Management System",
  "main": "index.js",
  "scripts": {
    "start": "concurrently \"npm run start:server\" \"npm run start:client\"",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "start:server": "cd backend && npm start",
    "dev:server": "cd backend && npm run dev",
    "start:client": "cd frontend && npm start",
    "dev:client": "cd frontend && npm run dev",
    "seed": "cd backend && npm run seed",
    "install:all": "npm install && cd backend && npm install && cd ../frontend && npm install"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}